{
  "buildCommand": "npm --prefix apps/web run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm --prefix apps/web install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
