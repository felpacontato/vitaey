{
  "buildCommand": "pnpm --dir apps/web run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm --dir apps/web install --frozen-lockfile",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
